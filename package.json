{
  "name": "@coceresroman/agentify",
  "version": "0.6.2",
  "description": "CLI tool to auto-detect project stacks and generate Claude Code configuration files",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "agentify": "bin/agentify.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc && npm run copy-templates",
    "copy-templates": "cp -r src/templates dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "automation",
    "stack-detection"
  ],
  "author": "Coceres Roman",
  "license": "GPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coceresroman/agentify.git"
  },
  "bugs": {
    "url": "https://github.com/coceresroman/agentify/issues"
  },
  "homepage": "https://github.com/coceresroman/agentify#readme",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "dist/templates"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^10.0.0",
    "handlebars": "^4.7.8",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "tsx": "^4.7.0"
  }
}

## Component Lifecycle

```js
import {
  onBeforeMount,
  onMounted,
  onBeforeUpdate,
  onUpdated,
  onBeforeUnmount,
  onUnmounted
} from 'vue';

onBeforeMount(() => {
  console.log('Before mount');
});

onMounted(() => {
  console.log('Mounted - DOM is ready');
  // Fetch data, setup listeners
});

onBeforeUpdate(() => {
  console.log('Before update');
});

onUpdated(() => {
  console.log('Updated - DOM re-rendered');
});

onBeforeUnmount(() => {
  console.log('Before unmount');
  // Cleanup listeners
});

onUnmounted(() => {
  console.log('Unmounted');
});
```

